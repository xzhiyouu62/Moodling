# 韓文歌曲推薦AI決策機器人環境配置
# 複製此文件為 .env 並填入你的設定值

# OpenAI API Key (用於AI解釋功能)
# 取得方式：https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Claude API Key (替代選項)
# 取得方式：https://console.anthropic.com/
CLAUDE_API_KEY=your-claude-api-key-here

# 應用設定
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your-secret-key-here

# 伺服器設定
HOST=0.0.0.0
PORT=5001

# 日誌等級 (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# 推薦設定
MAX_RECOMMENDATIONS=5
DEFAULT_RECOMMENDATION_COUNT=5

# 是否啟用真實LLM API (設為false則使用模擬解釋)
ENABLE_REAL_LLM=false